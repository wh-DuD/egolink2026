  {
    "tool_name": "compute_total_payment",
    "parameters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "restaurant_name": {
          "type": "string",
          "description": "Name of the restaurant."
        },
        "user_id": {
          "type": "string",
          "description": "The unique identifier of the user"
        },
        "dishes": {
          "type": "array",
          "description": "List of dishes to calculate total payment for",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "dish_name": {
                "type": "string",
                "description": "Name of the dish"
              },
              "quantity": {
                "type": "integer",
                "description": "Quantity of the dish to purchase"
              }
            },
            "required": [
              "dish_name",
              "quantity"
            ]
          }
        }
      },
      "required": [
        "restaurant_name",
        "user_id",
        "dishes"
      ]
    },
    "description": "Compute total payable amount for the specified dishes: sum(price * discount * qty). If a set meal has no set_meal_price, it is priced from its included dishes."
  },
  {
    "tool_name": "compute_total_tax",
    "parameters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "restaurant_name": {
          "type": "string",
          "description": "Name of the restaurant."
        },
        "user_id": {
          "type": "string",
          "description": "The unique identifier of the user"
        },
        "dishes": {
          "type": "array",
          "description": "List of dishes to calculate total tax for",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "dish_name": {
                "type": "string",
                "description": "Name of the dish"
              },
              "quantity": {
                "type": "integer",
                "description": "Quantity of the dish to purchase"
              }
            },
            "required": [
              "dish_name",
              "quantity"
            ]
          }
        }
      },
      "required": [
        "restaurant_name",
        "user_id",
        "dishes"
      ]
    },
    "description": "Compute total tax amount for the specified dishes. Since price is tax-inclusive, tax per item = (price * tax_rate / (1 + tax_rate)) * discount * qty."
  },
