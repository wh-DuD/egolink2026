[
  {
    "type": "function",
    "function": {
      "tool_name": "add_dish_to_catalog",
      "description": "Add or update a dish in the restaurant's catalog. Each dish must have a unique name, category, price, discount factor, nutritional tags, taste profile, allergens, and nutrition facts.",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "restaurant_name": {
            "type": "string",
            "description": "Name of the restaurant."
          },
          "dish_name": {
            "type": "string",
            "description": "Unique dish name (primary key)."
          },
          "category": {
            "type": "string",
            "enum": [
              "Pizza",
              "Pasta",
              "Salads",
              "Sandwiches & Panini",
              "Antipasti & Snacks",
              "Cheese & Olives",
              "Cold Cuts",
              "Handmade Bread",
              "Annie's top dishes",
              "Appetizers",
              "Desserts",
              "Italian Pasta",
              "Main Courses",
              "Seafood",
              "Selected Steaks",
              "Sides",
              "Soups"
            ]
          },
          "price": {
            "type": "number",
            "minimum": 0,
            "description": "Shelf price including tax."
          },
          "tax_rate": {
            "type": "number",
            "minimum": 0,
            "description": "Tax rate (e.g., 0.08 for 8%)."
          },
          "discount": {
            "type": "number",
            "minimum": 0,
            "maximum": 1.0,
            "description": "Discount factor: final amount = price * discount."
          },
          "nutritional_characteristics": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "low_calories",
                "low_fat",
                "low_sugar",
                "low_sodium",
                "no_additives",
                "high_fiber",
                "high_protein",
                "high_calcium",
                "sugar_free",
                "gluten_free",
                "high_omega3",
                "vegan",
                "high_antioxidants",
                "high_calories",
                "high_carbs",
                "high_fat",
                "high_healthy_fats",
                "high_iron",
                "high_monounsaturated_fat",
                "high_sodium",
                "high_sugar",
                "high_vitaminA",
                "low_protein"
              ]
            },
            "description": "Nutritional/health tags."
          },
          "taste": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "sweet",
                "salty",
                "spicy",
                "sour",
                "bitter",
                "umami",
                "mild",
                "savory",
                "smoky",
                "buttery",
                "creamy",
                "earthy",
                "fresh",
                "fruity",
                "garlicky",
                "herby",
                "nutty",
                "pungent",
                "rich",
                "tart"
              ]
            },
            "description": "Taste profiles."
          },
          "allergens": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "nutrition": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "basis": {
                "type": "string",
                "enum": [
                  "PER_100G",
                  "PER_SERVING",
                  "PER_125G",
                  "PER_235G",
                  "PER_250G",
                  "PER_BOX",
                  "PER_PIECE"
                ]
              },
              "serving_size_g": {
                "type": "number"
              },
              "calories_kcal": {
                "type": "number"
              },
              "protein_g": {
                "type": "number"
              },
              "fat_g": {
                "type": "number"
              },
              "carbs_g": {
                "type": "number"
              },
              "sugar_g": {
                "type": "number"
              },
              "sodium_mg": {
                "type": "number"
              },
              "fiber_g": {
                "type": "number"
              }
            },
            "required": [
              "basis"
            ]
          }
        },
        "required": [
          "restaurant_name",
          "dish_name",
          "category",
          "price",
          "tax_rate",
          "discount",
          "nutritional_characteristics",
          "taste",
          "allergens",
          "nutrition"
        ]
      }
    }
  },
