  {
    "type": "function",
    "function": {
      "tool_name": "compute_total_payment",
      "description": "Compute total payable amount for the specified products: sum(price * discount * qty).",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "user_id": {
            "type": "string",
            "description": "The unique identifier of the user"
          },
          "products": {
            "type": "array",
            "description": "List of products to calculate total payment for",
            "items": {
              "type": "object",
              "properties": {
                "product_name": {
                  "type": "string",
                  "description": "Name of the product"
                },
                "quantity": {
                  "type": "integer",
                  "description": "Quantity of the product to purchase"
                }
              },
              "required": [
                "product_name",
                "quantity"
              ]
            }
          }
        },
        "required": [
          "user_id",
          "products"
        ]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "tool_name": "compute_total_tax",
      "description": "Compute total tax amount for the specified products. Since price is tax-inclusive, tax per item = (price * tax_rate / (1 + tax_rate)) * discount * qty.",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "user_id": {
            "type": "string",
            "description": "The unique identifier of the user"
          },
          "products": {
            "type": "array",
            "description": "List of products to calculate total tax for",
            "items": {
              "type": "object",
              "properties": {
                "product_name": {
                  "type": "string",
                  "description": "Name of the product"
                },
                "quantity": {
                  "type": "integer",
                  "description": "Quantity of the product to purchase"
                }
              },
              "required": [
                "product_name",
                "quantity"
              ]
            }
          }
        },
        "required": [
          "user_id",
          "products"
        ]
      }
    }
  },
